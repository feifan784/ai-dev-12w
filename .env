LLM_API_KEY=sk-900bc88a9559452a8b34989077283d7a
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========================================
# Ollama 本地模型配置
# ========================================

# Ollama API 地址（默认端口 11434，通常不需要修改）
OLLAMA_BASE_URL=http://localhost:11434

# 模型名称（通过 `ollama list` 查看已下载的模型）
# 常用模型：
#   - qwen:7b         通义千问 7B 版本
#   - qwen:1.8b       通义千问 1.8B 轻量版（速度快）
#   - qwen:0.5b       通义千问 0.5B 超轻量版
#   - llama3.2:3b     Meta Llama 3.2
OLLAMA_MODEL=qwen:7b

# ========================================
# 模型参数配置（可选）
# ========================================

# 温度参数 (0-1)，越高回复越随机创造性，越低越保守
# 默认: 0.7
OLLAMA_TEMPERATURE=0.7

# 最大输出 token 数（限制回复长度）
# 默认: 2048
OLLAMA_MAX_TOKENS=2048

# Top-p 采样，控制词汇选择的多样性 (0-1)
# 默认: 0.9
OLLAMA_TOP_P=0.9

# ========================================
# 注意：本地 Ollama 不需要 API Key！
# ========================================